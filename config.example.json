{
  "ollama_host": "http://localhost:11434",
  "keep_alive": "5m",
  "models": {
    "brain": "qwen3:8b",
    "coder": "qwen2.5-coder:7b"
  },
  "think_by_default": false,
  "max_steps": 12,
  "browser_app": "Google Chrome",
  "max_tool_output_chars": 6000,
  "google": {
    "default_account": "personal",
    "accounts": ["personal"]
  },
  "email": {
    "default_account": "private",
    "accounts": {
      "private": {
        "address": "you@yourdomain.com",
        "imap_host": "mail.privateemail.com",
        "imap_port": 993,
        "smtp_host": "mail.privateemail.com",
        "smtp_port": 465,
        "password_env": "PRIVATE_EMAIL_PW"
      }
    }
  },
  "secret_patterns": [
    { "name": "OpenAI API key",            "regex": "sk-(proj-)?[A-Za-z0-9_-]{20,}" },
    { "name": "Anthropic API key",         "regex": "sk-ant-[A-Za-z0-9_-]{20,}" },
    { "name": "AWS access key id",         "regex": "AKIA[0-9A-Z]{16}" },
    { "name": "AWS secret access key",     "regex": "aws_secret_access_key\\s*[:=]\\s*['\"]?[A-Za-z0-9/+]{30,}" },
    { "name": "GitHub token",              "regex": "gh[pousr]_[A-Za-z0-9]{30,}" },
    { "name": "GitHub fine-grained token", "regex": "github_pat_[A-Za-z0-9_]{40,}" },
    { "name": "Google API key",            "regex": "AIza[0-9A-Za-z_-]{35}" },
    { "name": "Slack token",               "regex": "xox[baprs]-[A-Za-z0-9-]{10,}" },
    { "name": "Stripe secret key",         "regex": "[rs]k_live_[A-Za-z0-9]{20,}" },
    { "name": "JWT",                       "regex": "eyJ[A-Za-z0-9_-]{10,}\\.eyJ[A-Za-z0-9_-]{10,}\\.[A-Za-z0-9_-]{10,}" },
    { "name": "Private key block",         "regex": "-----BEGIN (RSA |EC |DSA |OPENSSH |PGP )?PRIVATE KEY-----" },
    { "name": "Bearer token",              "regex": "[Bb]earer\\s+[A-Za-z0-9._-]{20,}" },
    { "name": "Generic secret assignment", "regex": "(?i)(api[_-]?key|secret|passwd|password|pwd|access[_-]?token|auth[_-]?token|client[_-]?secret)\\s*[:=]\\s*['\"][^'\"]{6,}['\"]" },
    { "name": "Connection string with credentials", "regex": "[a-zA-Z][a-zA-Z0-9+.-]*://[^:@/\\s]+:[^@/\\s]+@" }
  ]
}
